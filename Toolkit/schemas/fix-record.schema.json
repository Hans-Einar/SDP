{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdp.local/schemas/fix-record.schema.json",
  "title": "SDP Fix Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "fixId", "targetVersion", "status",
    "reasonFullSliceIsDisproportionate", "scope", "expectedFiles",
    "invariants", "nonGoals", "verification", "reviewRecord", "revision"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "fixId": { "type": "string", "pattern": "^(FIX|HOTFIX)-[0-9]+\\.[0-9]+\\.[0-9]+-[0-9]{3}$" },
    "targetVersion": { "$ref": "#/$defs/semver" },
    "status": { "enum": ["planned", "active", "verification", "review", "complete", "cancelled"] },
    "reasonFullSliceIsDisproportionate": { "type": "string", "minLength": 1 },
    "scope": { "type": "array", "items": { "type": "string" } },
    "expectedFiles": { "type": "array", "items": { "type": "string" } },
    "invariants": { "type": "array", "items": { "type": "string" } },
    "nonGoals": { "type": "array", "items": { "type": "string" } },
    "verification": { "type": "array", "items": { "type": "string" } },
    "reviewRecord": { "type": ["string", "null"] },
    "revision": { "type": ["integer", "null"], "minimum": 1 }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    }
  }
}
