{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdp.local/schemas/SDP-project-manifest.schema.json",
  "title": "SDP Project Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "project", "installed", "release", "development", "migration"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "project": {
      "type": "object",
      "required": ["name", "capabilities"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "capabilities": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "installed": {
      "type": "object",
      "required": ["manifestPath"],
      "properties": { "manifestPath": { "$ref": "#/$defs/portablePath" } },
      "additionalProperties": false
    },
    "release": {
      "type": "object",
      "required": ["currentVersion", "nextTargetVersion", "state", "latestTag", "latestCommit"],
      "properties": {
        "currentVersion": { "$ref": "#/$defs/semver" },
        "nextTargetVersion": {
          "anyOf": [
            { "$ref": "#/$defs/semver" },
            { "type": "null" }
          ]
        },
        "state": { "enum": ["unreleased", "prerelease", "released", "yanked"] },
        "latestTag": {
          "oneOf": [
            { "$ref": "#/$defs/versionTag" },
            { "type": "null" }
          ]
        },
        "latestCommit": { "type": ["string", "null"], "minLength": 7 }
      },
      "additionalProperties": false
    },
    "development": {
      "type": "object",
      "required": ["sprintId", "refactorId", "iterationId", "sliceId", "fixId", "revision"],
      "properties": {
        "sprintId": { "type": ["string", "null"] },
        "refactorId": { "type": ["string", "null"] },
        "iterationId": { "type": ["string", "null"] },
        "sliceId": { "type": ["string", "null"] },
        "fixId": { "type": ["string", "null"] },
        "revision": { "type": ["integer", "null"], "minimum": 1 }
      },
      "allOf": [
        {
          "not": {
            "properties": {
              "sprintId": { "type": "string" },
              "refactorId": { "type": "string" }
            },
            "required": ["sprintId", "refactorId"]
          }
        }
      ],
      "additionalProperties": false
    },
    "migration": {
      "type": "object",
      "required": ["pendingWarnings"],
      "properties": { "pendingWarnings": { "type": "array", "items": { "type": "string" } } },
      "additionalProperties": false
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-((?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
    },
    "versionTag": {
      "type": "string",
      "pattern": "^v(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-((?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+([0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*))?$"
    },
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*[\\\\<>:\"|?*~\\u0000-\\u001F\\u007F])(?!.*//)(?!.*\\/$)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*(?:^|/)\\.[Gg][Ii][Tt](?:/|$))(?!.*(?:^|/)(?:[Cc][Oo][Nn]|[Pp][Rr][Nn]|[Aa][Uu][Xx]|[Nn][Uu][Ll]|[Cc][Ll][Oo][Cc][Kk]\\$|[Cc][Oo][Nn][Ii][Nn]\\$|[Cc][Oo][Nn][Oo][Uu][Tt]\\$|[Cc][Oo][Mm](?:[1-9]|\\u00B9|\\u00B2|\\u00B3)|[Ll][Pp][Tt](?:[1-9]|\\u00B9|\\u00B2|\\u00B3))(?:\\.[^/]*)?(?:/|$))(?!.*[. ](?:/|$)).+$"
    }
  }
}
