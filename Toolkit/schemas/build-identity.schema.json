{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdp.local/schemas/build-identity.schema.json",
  "title": "SDP Generated Build Identity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "releaseVersion", "releaseState", "sprintId", "refactorId",
    "iterationId", "sliceId", "fixId", "revision", "commit", "shortCommit",
    "buildTimestamp", "dirty", "developmentId", "displayVersion"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "releaseVersion": { "$ref": "#/$defs/semver" },
    "releaseState": { "enum": ["unreleased", "prerelease", "released", "yanked"] },
    "sprintId": { "type": ["string", "null"] },
    "refactorId": { "type": ["string", "null"] },
    "iterationId": { "type": ["string", "null"] },
    "sliceId": { "type": ["string", "null"] },
    "fixId": { "type": ["string", "null"] },
    "revision": { "type": ["integer", "null"], "minimum": 1 },
    "commit": { "type": ["string", "null"] },
    "shortCommit": { "type": ["string", "null"] },
    "buildTimestamp": { "type": "string", "format": "date-time" },
    "dirty": { "type": ["boolean", "null"] },
    "developmentId": { "type": "string", "minLength": 1 },
    "displayVersion": { "type": "string", "minLength": 1 }
  },
  "allOf": [
    {
      "not": {
        "properties": {
          "sprintId": { "type": "string" },
          "refactorId": { "type": "string" }
        },
        "required": ["sprintId", "refactorId"]
      }
    }
  ],
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    }
  }
}
