{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdp.local/schemas/installed-toolkit-manifest.schema.json",
  "title": "Installed SDP Toolkit Facts",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "toolkitVersion",
    "frameworkVersion",
    "agentsContractVersion",
    "installerVersion",
    "toolkitInstalledAt",
    "sourceCommit",
    "skills",
    "capabilities"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "toolkitVersion": { "$ref": "#/$defs/semver" },
    "frameworkVersion": { "$ref": "#/$defs/semver" },
    "agentsContractVersion": { "$ref": "#/$defs/semver" },
    "installerVersion": { "$ref": "#/$defs/semver" },
    "toolkitInstalledAt": { "type": "string", "format": "date-time" },
    "sourceCommit": { "type": ["string", "null"] },
    "skills": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/semver" }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    }
  }
}
