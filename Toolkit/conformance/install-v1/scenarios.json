      },
      "assertions": {
        "planningPreservesTree": true
      }
    },
    {
      "id": "repeat-initialize",
      "categories": ["repeat", "repeat-initialize"],
      "sourceMode": "archive-no-git",
      "options": {
        "initializeProjectStructure": true,
        "forceManagedFiles": false
      },
      "before": {
        "profile": "installed-initialize",
