{
  "schemaVersion": "1.0",
  "contractId": "sdp-install-conformance",
  "orderingPolicy": "migration-first-manifest-order-v1",
  "failureClasses": [
    "install-manifest-invalid",
    "agents-migration-destination-content-mismatch",
    "agents-migration-destination-unsupported-object",
    "agents-migration-source-changed",
    "agents-migration-destination-changed"
  ],
  "scenarios": [
    {
      "id": "empty-default",
      "categories": ["empty"],
      "sourceMode": "archive-no-git",
      "options": {
        "initializeProjectStructure": false,
        "forceManagedFiles": false
      },
      "before": {
        "profile": "empty",
        "directories": [],
        "files": []
      },
      "expected": {
        "kind": "applicable-plan",
        "path": "expected/empty-default.plan.json"
      },
      "assertions": {
        "planningPreservesTree": true,
        "afterApply": {
          "absentPaths": ["SDP/Releases/REL-0.2.0.yaml"]
        }
      }
    },
    {
      "id": "empty-initialize",
      "categories": ["empty", "initialize"],
      "sourceMode": "archive-no-git",
      "options": {
        "initializeProjectStructure": true,
        "forceManagedFiles": false
      },
      "before": {
        "profile": "empty",
        "directories": [],
        "files": []
      },
      "expected": {
        "kind": "applicable-plan",
        "path": "expected/empty-initialize.plan.json"
      },
      "assertions": {
        "planningPreservesTree": true,
        "afterApply": {
          "absentPaths": ["SDP/Releases/REL-0.2.0.yaml"]
        }
      }
    },
    {
      "id": "repeat-default",
      "categories": ["repeat"],
      "sourceMode": "archive-no-git",
