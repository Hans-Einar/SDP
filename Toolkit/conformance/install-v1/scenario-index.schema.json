{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdp.local/conformance/install-v1/scenario-index.schema.json",
  "title": "SDP install-v1 language-neutral conformance scenarios",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contractId",
    "orderingPolicy",
    "failureClasses",
    "scenarios"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "contractId": { "const": "sdp-install-conformance" },
    "orderingPolicy": { "const": "migration-first-manifest-order-v1" },
    "failureClasses": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/failureClass" }
    },
    "scenarios": {
      "type": "array",
      "minItems": 17,
      "items": { "$ref": "#/$defs/scenario" }
    }
  },
  "$defs": {
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*//)(?!.*\\/$)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*(?:^|/)\\.[Gg][Ii][Tt](?:/|$)).+$"
    },
    "failureClass": {
      "enum": [
        "install-manifest-invalid",
        "agents-migration-destination-content-mismatch",
        "agents-migration-destination-unsupported-object",
        "agents-migration-source-changed",
        "agents-migration-destination-changed"
      ]
    },
    "fileDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "$ref": "#/$defs/portablePath" },
        "contentUtf8": { "type": "string" },
        "contentBase64": {
          "type": "string",
          "contentEncoding": "base64"
        }
      },
      "oneOf": [
        { "required": ["contentUtf8"] },
        { "required": ["contentBase64"] }
      ]
    },
    "before": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "directories", "files"],
      "properties": {
        "profile": {
          "enum": ["empty", "installed-default", "installed-initialize"]
        },
        "installedManifestFacts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "toolkitVersion": {
              "type": "string",
              "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
            }
          }
        },
        "directories": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/portablePath" }
        },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/fileDeclaration" }
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": {
          "enum": ["applicable-plan", "blocked-plan", "fatal"]
        },
        "path": {
          "allOf": [
            { "$ref": "#/$defs/portablePath" },
            {
              "pattern": "^expected/[a-z][a-z0-9-]*\\.(?:plan|failure)\\.json$"
            }
          ]
        }
      }
    },
    "fileAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/portablePath" },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "containsAssertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "value"],
      "properties": {
        "path": { "$ref": "#/$defs/portablePath" },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planningPreservesTree"],
      "properties": {
        "planningPreservesTree": { "const": true },
        "afterApply": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "files": {
              "type": "array",
              "items": { "$ref": "#/$defs/fileAssertion" }
            },
            "absentPaths": {
              "type": "array",
              "items": { "$ref": "#/$defs/portablePath" }
            },
            "utf8Contains": {
              "type": "array",
              "items": { "$ref": "#/$defs/containsAssertion" }
            }
          }
        }
      }
    },
    "manifestMutation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["op", "path", "value"],
      "properties": {
        "op": { "const": "replace" },
        "path": { "const": "/orderingPolicy" },
        "value": { "type": "string" }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "categories",
        "sourceMode",
        "options",
        "before",
        "expected",
        "assertions"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
        },
        "categories": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "empty",
              "initialize",
              "repeat",
              "repeat-initialize",
              "legacy",
              "upgrade",
              "force",
              "project-owned",
              "archive",
              "error"
            ]
          }
        },
        "sourceMode": { "const": "archive-no-git" },
        "options": {
          "type": "object",
          "additionalProperties": false,
          "required": ["initializeProjectStructure", "forceManagedFiles"],
          "properties": {
            "initializeProjectStructure": { "type": "boolean" },
            "forceManagedFiles": { "type": "boolean" }
          }
        },
        "before": { "$ref": "#/$defs/before" },
        "sourceManifestMutations": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/manifestMutation" }
        },
        "expected": { "$ref": "#/$defs/expected" },
        "assertions": { "$ref": "#/$defs/assertions" }
      }
    }
  }
}
